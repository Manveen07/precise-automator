APP_ENV=local
APP_BASE_URL=http://localhost:8000
APP_SECRET_KEY=replace_me
APP_USERNAME=admin
APP_PASSWORD=replace_me

# MongoDB Atlas connection (do NOT commit real credentials)
MONGODB_URL=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?authSource=admin
MONGODB_DB_NAME=infrabot

# Anthropic for AI revisions and spintax
ANTHROPIC_API_KEY=replace_me
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Smartlead workspace API keys
SMARTLEAD_PRECISELEAD_API_KEY=replace_me
SMARTLEAD_BELARDI_WONG_API_KEY=replace_me
SMARTLEAD_DARLEAN_API_KEY=replace_me
SMARTLEAD_MYTHIC_API_KEY=replace_me

# HeyReach workspace API keys (per workspace)
HEYREACH_PRECISELEAD_API_KEY=replace_me
HEYREACH_BELARDI_WONG_API_KEY=replace_me
HEYREACH_DARLEAN_API_KEY=replace_me
HEYREACH_MYTHIC_API_KEY=replace_me

# Inbox selection sheet (Google Apps Script Web App returning a JSON 2D array)
INBOX_SHEET_WEBAPP_URL=
INBOX_SHEET_TAB=All Inboxes

# Optional outbound notifications
SLACK_WEBHOOK_URL=

# Optional Slack relay monitor. Required for interactive Resume Campaign actions.
SMARTLEAD_WEBHOOK_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=
BOUNCE_PROTECTION_THRESHOLD=0.03
